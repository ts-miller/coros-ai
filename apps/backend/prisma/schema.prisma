// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id           Int       @id @default(autoincrement())
  corosEmail   String
  corosPwd     String    // AES-256 encrypted
  accessToken  String?
  userId       String?
  unitSystem   String    @default("metric")  // "metric" | "imperial"
  updatedAt    DateTime  @updatedAt
}

/// Structured training goal — one row, upserted on save.
model Goal {
  id                 Int       @id @default(autoincrement())
  goalType           String    @default("BASE_BUILDING") // RACE | BASE_BUILDING | JUST_RUN
  raceDistance       String?   // 5K | 10K | HALF_MARATHON | MARATHON | 50K | 50_MILE | 100K | 100_MILE
  targetTimeSeconds  Int?      // optional goal finish time in seconds
  raceDate           DateTime? // target race day
  experienceLevel    String    @default("INTERMEDIATE") // BEGINNER | INTERMEDIATE | ADVANCED
  daysPerWeek        Int       @default(4) // 3–7 training days per week
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Activity {
  id            Int      @id @default(autoincrement())
  labelId       String   @unique
  date          Int      // YYYYMMDD
  sportType     Int      // 100=Run, 101=IndoorRun, 102=TrailRun, 103=TrackRun
  name          String
  distance      Float    // metres
  totalTime     Int      // seconds
  avgHr         Int?
  maxHr         Int?
  avgPace       Float?   // seconds per km
  trainingLoad  Float?
  aerobicEffect Float?
  calories      Int?
  startTime     BigInt?
  endTime       BigInt?
  rawSummary    Json?    // full summary object from Coros
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
}

model HealthMetric {
  id             Int      @id @default(autoincrement())
  date           Int      @unique // YYYYMMDD
  sleepDuration  Float?   // hours
  restingHr      Int?     // bpm
  hrv            Float?   // ms
  isMock         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum WorkoutStatus {
  PENDING
  PUSHED
  FAILED
  SKIPPED
}

model WorkoutPlan {
  id             Int           @id @default(autoincrement())
  date           Int           // YYYYMMDD
  title          String
  description    String
  stepsJson      Json          // AI-generated structured workout steps
  status         WorkoutStatus @default(PENDING)
  corosWorkoutId String?       // set after successful push
  pushError      String?       // error message if push failed
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([date])
  @@index([status])
}
