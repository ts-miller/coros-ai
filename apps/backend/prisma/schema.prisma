// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  goals     Goal[]
  settings  Settings?
  createdAt DateTime @default(now())
}

model Settings {
  id           Int       @id @default(autoincrement())
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])
  corosEmail   String
  corosPwd     String    // AES-256 encrypted
  accessToken  String?
  corosUserId  String?   // Coros-specific user ID
  unitSystem   String    @default("metric")  // "metric" | "imperial"
  updatedAt    DateTime  @updatedAt
}

/// Structured training goals
model Goal {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  title               String
  type                GoalType
  status              GoalStatus @default(ACTIVE)
  isPrimary           Boolean   @default(false)

  // Specific Goal Metrics
  raceDistance        String?
  targetDate          DateTime?
  targetTimeSeconds   Int?

  // Progress Tracking
  progressStatus      ProgressStatus @default(NOT_EVALUATED)
  progressNotes       String?   // AI's brief explanation for the status

  // Training Parameters
  experienceLevel     ExperienceLevel @default(INTERMEDIATE)
  trainingDaysPerWeek Int             @default(4)

  // AI Coaching Flags
  aiWarningIgnored    Boolean   @default(false)
  archivedReason      String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

enum GoalType {
  RACE
  PACE
  DISTANCE
  JUST_RUN
  BASE_BUILDING
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgressStatus {
  ON_TRACK
  FALLING_BEHIND
  AHEAD
  NOT_EVALUATED
}

model Activity {
  id            Int      @id @default(autoincrement())
  labelId       String   @unique
  date          Int      // YYYYMMDD
  sportType     Int      // 100=Run, 101=IndoorRun, 102=TrailRun, 103=TrackRun
  name          String
  distance      Float    // metres
  totalTime     Int      // seconds
  avgHr         Int?
  maxHr         Int?
  avgPace       Float?   // seconds per km
  trainingLoad  Float?
  aerobicEffect Float?
  calories      Int?
  startTime     BigInt?
  endTime       BigInt?
  rawSummary    Json?    // full summary object from Coros
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
}

model HealthMetric {
  id             Int      @id @default(autoincrement())
  date           Int      @unique // YYYYMMDD
  sleepDuration  Float?   // hours
  restingHr      Int?     // bpm
  hrv            Float?   // ms
  isMock         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum WorkoutStatus {
  PENDING
  PUSHED
  FAILED
  SKIPPED
}

model WorkoutPlan {
  id             Int           @id @default(autoincrement())
  date           Int           // YYYYMMDD
  title          String
  description    String
  stepsJson      Json          // AI-generated structured workout steps
  status         WorkoutStatus @default(PENDING)
  corosWorkoutId String?       // set after successful push
  pushError      String?       // error message if push failed
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([date])
  @@index([status])
}
