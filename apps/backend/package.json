{
  "name": "@coros-ai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "tsx src/index.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test:api": "tsx scripts/test-api.ts",
    "test:coros": "tsx scripts/test-coros-auth.ts",
    "test:all": "tsx scripts/test-coros-auth.ts && tsx scripts/test-api.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "md5": "^2.3.0",
    "node-cron": "^3.0.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
